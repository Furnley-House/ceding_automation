VITE_API_URL=http://localhost:3001/api

# When "true" the app skips the in-app role picker and demo-login tiles,
# auto-redirecting to Microsoft Entra SSO on every unauthenticated route.
# Set to "true" in .env.production for prod builds. Leave unset (or "false")
# locally so developers can switch roles without leaving the keyboard.
# VITE_DISABLE_DEMO_LOGIN=true
