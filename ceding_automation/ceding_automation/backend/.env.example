# ─────────────────────────────────────────────────────────
# Furnley House – Ceding Automation Backend Environment
# Copy this to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ceding_automation"

# ── SERVER ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── AUTH / JWT ────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=8h

# ── AZURE OPENAI (Production AI layer) ────────────────────
# These are set up separately per the AI architecture
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── AZURE BLOB STORAGE ────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=furnleyhouseceding
AZURE_STORAGE_ACCOUNT_KEY=your-storage-account-key
AZURE_STORAGE_CONTAINER_NAME=ceding-documents

# ── ZOHO CRM ──────────────────────────────────────────────
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
ZOHO_ORG_ID=your-zoho-org-id

# ── ZOHO WORKDRIVE ────────────────────────────────────────
ZOHO_WORKDRIVE_TEAM_ID=your-workdrive-team-id
ZOHO_WORKDRIVE_FOLDER_ID=your-default-folder-id

# ── RINGCENTRAL ───────────────────────────────────────────
# 1. Create a Server/Bot app in https://developers.ringcentral.com
# 2. Enable scopes: RingOut, CallLog, ReadCallRecording, ReadAccounts
# 3. Generate a JWT credential in the app's Credentials tab
RINGCENTRAL_CLIENT_ID=your-ringcentral-client-id
RINGCENTRAL_CLIENT_SECRET=your-ringcentral-client-secret
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
RINGCENTRAL_JWT=your-jwt-credential-from-rc-developer-portal
# The agent's direct-dial number that will ring first on each outbound call
RINGCENTRAL_AGENT_PHONE=+441234567890

# ── PALINDROME ────────────────────────────────────────────
PALINDROME_API_KEY=your-palindrome-api-key
PALINDROME_API_URL=https://api.palindrome.ai

# ── AZURE AD SSO ─────────────────────────────────────────
# Microsoft Entra ID (Azure AD) — server-side OAuth 2.0 / OIDC flow.
# 1. Register a "Web" platform in your Azure app with redirect URI below.
# 2. Ensure scopes: openid, profile, email (granted under API permissions).
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
# Redirect URI must match exactly what is registered in the Azure app.
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/azure/callback

# ── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
